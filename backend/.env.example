# PostgreSQL connection string for SignalCore AI
# Get a free database from https://neon.tech or https://supabase.com
# Format: postgresql://user:password@host:port/dbname?sslmode=require
# Set to "sqlite" to use local SQLite fallback (default for development)
DATABASE_URL=sqlite

# Webhook Secrets
SHOPIFY_WEBHOOK_SECRET=your_shopify_secret_here
WOOCOMMERCE_WEBHOOK_SECRET=your_woocommerce_secret_here
